{
  "name": "skillbook-agents",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "validate:skills": "node --experimental-strip-types scripts/validate-skills.ts",
    "fix:skills": "node --experimental-strip-types scripts/autofix-skills.ts",
    "new:skill": "node --experimental-strip-types scripts/new-skill.ts",
    "build": "npm run validate:skills && next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.174.0",
    "html2canvas": "^1.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.174.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
